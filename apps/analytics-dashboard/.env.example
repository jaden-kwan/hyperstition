# Apify — https://console.apify.com/settings/integrations
APIFY_TOKEN=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: pin which Apify Twitter/X scraper actor to use.
# Default (apidojo/tweet-scraper) is set in pipeline/src/pipeline/scrape.py.
# APIFY_TWITTER_ACTOR=apidojo/tweet-scraper

# Optional: model used for coding posts. Default in code.py.
# CODER_MODEL=claude-sonnet-4-6
